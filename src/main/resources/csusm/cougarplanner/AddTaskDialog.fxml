<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox spacing="12.0"
      styleClass="app-panel-header"
      style="-fx-background-radius: 10; -fx-padding: 20; -fx-min-width: 400;"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="csusm.cougarplanner.controllers.AddTaskDialogController">

    <Label text="Add Task" textFill="white">
        <font><Font name="Arial Rounded MT Bold" size="18.0"/></font>
    </Label>

    <!-- Title -->
    <VBox spacing="4.0">
        <Label text="Title" textFill="white">
            <font><Font name="Arial Rounded MT Bold" size="12.0"/></font>
        </Label>
        <TextField fx:id="titleField"
                   promptText="Task Title"
                   style="-fx-background-radius: 6; -fx-font-family: 'Arial Rounded MT Bold'; -fx-font-size: 13;" />
    </VBox>

    <!-- Due Date -->
    <VBox spacing="4.0">
        <Label text="Due Date" textFill="white">
            <font><Font name="Arial Rounded MT Bold" size="12.0"/></font>
        </Label>
        <DatePicker fx:id="dueDatePicker" maxWidth="Infinity"
                    style="-fx-background-radius: 6; -fx-font-family: 'Arial Rounded MT Bold';" />
    </VBox>

    <!-- Description -->
    <VBox spacing="4.0">
        <Label text="Description" textFill="white">
            <font><Font name="Arial Rounded MT Bold" size="12.0"/></font>
        </Label>
        <TextArea fx:id="descriptionArea"
                  prefHeight="70.0"
                  promptText="Task description"
                  style="-fx-background-radius: 6; -fx-font-family: 'Arial Rounded MT Bold'; -fx-font-size: 13;"
                  wrapText="true" />
    </VBox>

    <!-- Course / Status / Priority row -->
    <HBox spacing="12.0">

        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label text="Course" textFill="white">
                <font><Font name="Arial Rounded MT Bold" size="12.0"/></font>
            </Label>
            <ComboBox fx:id="courseComboBox" maxWidth="Infinity" promptText="choose course"
                      style="-fx-background-radius: 6;" HBox.hgrow="ALWAYS"/>
        </VBox>

        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label text="Status" textFill="white">
                <font><Font name="Arial Rounded MT Bold" size="12.0"/></font>
            </Label>
            <ComboBox fx:id="statusComboBox" maxWidth="Infinity"
                      style="-fx-background-radius: 6;" HBox.hgrow="ALWAYS"/>
        </VBox>

        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label text="Priority" textFill="white">
                <font><Font name="Arial Rounded MT Bold" size="12.0"/></font>
            </Label>
            <ComboBox fx:id="priorityComboBox" maxWidth="Infinity"
                      style="-fx-background-radius: 6;" HBox.hgrow="ALWAYS"/>
        </VBox>

    </HBox>

    <!-- Error -->
    <Label fx:id="errorLabel" text="" style="-fx-text-fill: #FF6B6B;" visible="false">
        <font><Font name="Arial Rounded MT Bold" size="12.0"/></font>
    </Label>

    <!-- Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button fx:id="cancelButton" text="Cancel" mnemonicParsing="false"
                onAction="#onCancelClicked"
                style="-fx-background-color: #BCBEC0; -fx-background-radius: 6;
                       -fx-font-family: 'Arial Rounded MT Bold'; -fx-font-size: 13;
                       -fx-padding: 5 16 5 16;" />
        <Button fx:id="saveButton" text="Add Task" mnemonicParsing="false"
                onAction="#onSaveClicked"
                style="-fx-background-color: #F8BA2B; -fx-background-radius: 6;
                       -fx-font-family: 'Arial Rounded MT Bold'; -fx-font-size: 13;
                       -fx-padding: 5 16 5 16;" />
    </HBox>

</VBox>
