<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="settingsPanelRoot"
            prefHeight="461.0"
            prefWidth="1015.0"
            style="-fx-background-color: #ffffff; -fx-background-radius: 2;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="csusm.cougarplanner.controllers.SettingsPanelController">

    <AnchorPane prefHeight="40.0"
                style="-fx-background-color: #002E5A; -fx-background-radius: 6 6 0 0;"
                AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <children>
            <Label text="Settings"
                   style="-fx-background-color: white; -fx-background-radius: 4; -fx-padding: 4 12 4 12;"
                   AnchorPane.leftAnchor="14.0" AnchorPane.topAnchor="8.0">
                <font><Font name="Arial Rounded MT Bold" size="14.0"/></font>
            </Label>
            <Label fx:id="closeButton" text="✕"
                   onMouseClicked="#onCloseClicked"
                   onMouseEntered="#onCloseHoverEnter"
                   onMouseExited="#onCloseHoverExit"
                   style="-fx-text-fill: white; -fx-background-color: transparent;
                          -fx-background-radius: 4; -fx-padding: 4 10 4 10; -fx-cursor: hand;"
                   AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="6.0">
                <font><Font name="Arial Rounded MT Bold" size="16.0"/></font>
            </Label>
        </children>
    </AnchorPane>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                style="-fx-background-color: transparent; -fx-background: transparent;"
                AnchorPane.topAnchor="40.0" AnchorPane.bottomAnchor="50.0"
                AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <content>
            <VBox spacing="14.0"
                  style="-fx-padding: 16 20 16 20; -fx-background-color: transparent;">
                <children>

                    <VBox spacing="10.0"
                          style="-fx-background-color: #f0f0f0; -fx-background-radius: 10; -fx-padding: 14;
                                 -fx-border-color: #cccccc; -fx-border-radius: 10; -fx-border-width: 1;">
                        <children>
                            <Label text="Show"
                                   style="-fx-text-fill: #222222;">
                                <font><Font name="Arial Rounded MT Bold" size="16.0"/></font>
                            </Label>
                            <HBox spacing="10.0">
                                <children>
                                    <Label fx:id="sortAnnouncementsLabel" text="Announcements"
                                           onMouseClicked="#onSortByClicked"
                                           onMouseEntered="#onOptionHoverEnter"
                                           onMouseExited="#onOptionHoverExit"
                                           style="-fx-background-color: white; -fx-text-fill: #222222;
                                                  -fx-background-radius: 8; -fx-border-color: #cccccc;
                                                  -fx-border-radius: 8; -fx-padding: 6 14 6 14; -fx-cursor: hand;">
                                        <font><Font name="Arial Rounded MT Bold" size="13.0"/></font>
                                    </Label>
                                    <Label fx:id="sortAssignmentsLabel" text="Assignments"
                                           onMouseClicked="#onSortByClicked"
                                           onMouseEntered="#onOptionHoverEnter"
                                           onMouseExited="#onOptionHoverExit"
                                           style="-fx-background-color: white; -fx-text-fill: #222222;
                                                  -fx-background-radius: 8; -fx-border-color: #cccccc;
                                                  -fx-border-radius: 8; -fx-padding: 6 14 6 14; -fx-cursor: hand;">
                                        <font><Font name="Arial Rounded MT Bold" size="13.0"/></font>
                                    </Label>
                                    <Label fx:id="sortTasksLabel" text="Tasks"
                                           onMouseClicked="#onSortByClicked"
                                           onMouseEntered="#onOptionHoverEnter"
                                           onMouseExited="#onOptionHoverExit"
                                           style="-fx-background-color: white; -fx-text-fill: #222222;
                                                  -fx-background-radius: 8; -fx-border-color: #cccccc;
                                                  -fx-border-radius: 8; -fx-padding: 6 14 6 14; -fx-cursor: hand;">
                                        <font><Font name="Arial Rounded MT Bold" size="13.0"/></font>
                                    </Label>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <VBox spacing="10.0"
                          style="-fx-background-color: #f0f0f0; -fx-background-radius: 10; -fx-padding: 14;
                                 -fx-border-color: #cccccc; -fx-border-radius: 10; -fx-border-width: 1;">
                        <children>
                            <Label text="Layout"
                                   style="-fx-text-fill: #222222;">
                                <font><Font name="Arial Rounded MT Bold" size="16.0"/></font>
                            </Label>
                            <HBox spacing="10.0">
                                <children>
                                    <Label fx:id="displayWeekLabel" text="Week"
                                           onMouseClicked="#onDisplayClicked"
                                           onMouseEntered="#onOptionHoverEnter"
                                           onMouseExited="#onOptionHoverExit"
                                           style="-fx-background-color: white; -fx-text-fill: #222222;
                                                  -fx-background-radius: 8; -fx-border-color: #cccccc;
                                                  -fx-border-radius: 8; -fx-padding: 6 14 6 14; -fx-cursor: hand;">
                                        <font><Font name="Arial Rounded MT Bold" size="13.0"/></font>
                                    </Label>
                                    <Label fx:id="displayDayLabel" text="Day"
                                           onMouseClicked="#onDisplayClicked"
                                           onMouseEntered="#onOptionHoverEnter"
                                           onMouseExited="#onOptionHoverExit"
                                           style="-fx-background-color: white; -fx-text-fill: #222222;
                                                  -fx-background-radius: 8; -fx-border-color: #cccccc;
                                                  -fx-border-radius: 8; -fx-padding: 6 14 6 14; -fx-cursor: hand;">
                                        <font><Font name="Arial Rounded MT Bold" size="13.0"/></font>
                                    </Label>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <VBox spacing="10.0"
                          style="-fx-background-color: #f0f0f0; -fx-background-radius: 10; -fx-padding: 14;
                                 -fx-border-color: #cccccc; -fx-border-radius: 10; -fx-border-width: 1;">
                        <children>
                            <Label text="Week Start"
                                   style="-fx-text-fill: #222222;">
                                <font><Font name="Arial Rounded MT Bold" size="16.0"/></font>
                            </Label>
                            <HBox spacing="10.0">
                                <children>
                                    <Label fx:id="weekStartSundayLabel" text="Sunday"
                                           onMouseClicked="#onWeekStartClicked"
                                           onMouseEntered="#onOptionHoverEnter"
                                           onMouseExited="#onOptionHoverExit"
                                           style="-fx-background-color: white; -fx-text-fill: #222222;
                                                  -fx-background-radius: 8; -fx-border-color: #cccccc;
                                                  -fx-border-radius: 8; -fx-padding: 6 14 6 14; -fx-cursor: hand;">
                                        <font><Font name="Arial Rounded MT Bold" size="13.0"/></font>
                                    </Label>
                                    <Label fx:id="weekStartMondayLabel" text="Monday"
                                           onMouseClicked="#onWeekStartClicked"
                                           onMouseEntered="#onOptionHoverEnter"
                                           onMouseExited="#onOptionHoverExit"
                                           style="-fx-background-color: white; -fx-text-fill: #222222;
                                                  -fx-background-radius: 8; -fx-border-color: #cccccc;
                                                  -fx-border-radius: 8; -fx-padding: 6 14 6 14; -fx-cursor: hand;">
                                        <font><Font name="Arial Rounded MT Bold" size="13.0"/></font>
                                    </Label>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                </children>
            </VBox>
        </content>
    </ScrollPane>

    <HBox alignment="CENTER" spacing="20.0"
          style="-fx-background-color: #d1d3d4; -fx-padding: 8;"
          AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <children>
            <Label text="Changes save automatically"
                   style="-fx-text-fill: #333333;">
                <font><Font name="Arial Rounded MT Bold" size="12.0"/></font>
            </Label>
        </children>
    </HBox>

</AnchorPane>
